# Copy this file to .env and replace with your real values:
#   cp .env.example .env
#
# Get your OpenAI key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-key-here

# Flask session signing key. Any long random string works.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
# A stable key keeps user sessions alive across server restarts.
FLASK_SECRET_KEY=change-me-to-a-long-random-string
